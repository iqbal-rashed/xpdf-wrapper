{
    "name": "node-xpdf",
    "version": "1.0.0",
    "license": "MIT",
    "main": "./lib/cjs/index.js",
    "module": "./lib/esm/index.js",
    "types": "./lib/types/index.d.ts",
    "exports": {
        "import": "./lib/esm/index.js",
        "require": "./lib/cjs/index.js"
    },
    "files": [
        "lib/**/*",
        "bin/**/*"
    ],
    "scripts": {
        "build:ts": "shx rm -rf ./lib && tsc -p ./configs/tsconfig.cjs.json && tsc -p ./configs/tsconfig.esm.json"
    },
    "bin": {
        "pdfinfo": "./bin/pdfinfo"
    },
    "devDependencies": {
        "@types/jest": "^29.4.0",
        "@types/node": "^18.14.1",
        "jest": "^29.4.3",
        "shx": "^0.3.4",
        "ts-node": "^10.9.1",
        "typescript": "^4.9.5"
    }
}
